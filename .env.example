# Discord
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=

# Hetzner Cloud
HETZNER_API_TOKEN=
HETZNER_SERVER_NAME=game-server
HETZNER_SERVER_TYPE=ccx23
HETZNER_LOCATION=nbg1
HETZNER_SSH_KEY_NAMES=

# Cloudflare DNS
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_RECORD_ID=
CLOUDFLARE_DOMAIN=game.example.com

# Game server
GAME_TYPE=
# The UDP port the bot queries to check server status and read the player list.
# This is how the bot knows who is online, when to delay/cancel auto-shutdown,
# and when the server is ready after /start. Getting this wrong means the bot
# will treat the server as always empty or never ready. Check your game's docs.
GAME_QUERY_PORT=
GAME_SERVER_READY_TIMEOUT_MS=600000
IDLE_CHECK_INTERVAL_MS=15000
IDLE_TIMEOUT_MS=900000
SHUTDOWN_GRACE_PERIOD_MS=120000
MAX_SNAPSHOTS_TO_KEEP=3
